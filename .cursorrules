    {
      "step": 19,
      "title": "Implémenter Backend - Docker",
      "folder": "backend/",
      "files": ["Dockerfile"],
      "code": "FROM python:3.11-slim, WORKDIR /app, COPY requirements.txt, pip install, COPY ., CMD python main.py"
