        "place.py (class Place)",
        "vehicule.py (class Vehicule)",
        "ticket.py (class Ticket)",
        "employee.py (class Employee)"
      ],
      "code": "SQLAlchemy ORM avec relations, pk, fk, unique, index"
    },
    {
