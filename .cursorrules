    {
      "step": 20,
      "title": "Implémenter Frontend - Docker",
      "folder": "frontend/agent-app/, frontend/client-app/, frontend/admin-app/",
      "files": ["Dockerfile"],
      "code": "FROM node:18, WORKDIR /app, COPY package.json, npm install, COPY ., npm run build, CMD npm run preview"
    },
    {
      "step": 21,
      "title": "Documentation",
      "folder": "docs/",
      "files": [
        "api.md (Documentation API complète avec tous endpoints, request/response, examples)",
        "frontend.md (Documentation frontend - composants, pages, services)",
        "deployment.md (Documentation déploiement - Docker, production)"
      ]
    },
    {
      "step": 22,
      "title": "README + Finitions",
      "folder": "racine/",
      "files": [
        "README.md (Installation, lancement, usage)",
        ".env.example (Variables d'environnement)",
        ".gitignore"
      ]
    }
  ],

  "code_requirements": {
    "backend": {
      "must": [
        "Type hints sur tous paramètres et returns (Python 3.11+)",
        "Docstrings sur toutes les fonctions et classes",
        "Architecture layered (interfaces → services → repositories → models)",
        "Repository pattern pour database (CRUD encapsulé)",
        "Service pattern pour business logic (CheckInService, CheckOutService, PaymentService)",
        "Custom exceptions métier (pas de génériques)",
        "Pydantic pour validation Request/Response",
        "SQLAlchemy ORM (pas de SQL raw)",
        "loguru pour logging (pas de print())",
        "Async endpoints FastAPI",
        "Tests pytest avec coverage > 80%"
      ],
      "must_not": [
        "print() pour logging",
        "Hardcode valeurs (utiliser settings)",
        "SQL raw",
        "Exceptions génériques (Exception, ValueError)",
        "Code business dans routes API"
      ]
    },
    "frontend": {
      "must": [
        "TypeScript strict (pas de any)",
        "Interfaces TypeScript pour tous les types",
        "Components React fonctionnels (pas de classes)",
        "Hooks React (useState, useEffect, useMutation)",
        "React Query pour data fetching",
        "React Router pour navigation",
        "Axios pour HTTP calls",
        "CSS/modern UX (Tailwind ou styled-components)",
        "Tests Vitest pour components",
        "Env variables pour API_BASE_URL"
      ],
      "must_not": [
        "any TypeScript",
        "Components React classes",
        "fetch() natif (utiliser axios)",
        "Hardcode API URL (utiliser env)",
        "State management complexe (Redux) - trop lourd"
      ]
    }
  },

  "quality_criteria": {
    "backend": [
      "✅ python -m pytest tests/ -v (tous tests passent)",
      "✅ pytest --cov=src --cov-report=term-missing (coverage > 80%)",
      "✅ python main.py (FastAPI serveur lancé)",
      "✅ http://localhost:8000/docs (OpenAPI docs visibles)",
      "✅ curl -X POST http://localhost:8000/api/check-in {...} (check-in fonctionne)",
      "✅ curl -X POST http://localhost:8000/api/payment {...} (payment fonctionne)",
      "✅ Code sans erreurs, PEP8 compliant",
      "✅ Type hints sur toutes fonctions",
