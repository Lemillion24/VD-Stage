  "api_examples": {
    "check_in": {
      "request": {
        "method": "POST",
        "url": "http://localhost:8000/api/check-in",
        "body": {
          "plate_number": "ABC123",
          "parking_id": 1,
          "vehicle_type": "sedan",
          "owner_name": "John Doe"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "success": true,
          "ticket_id": "TKT-2024-001",
          "place_number": "P-101",
          "entry_time": "2024-01-15T10:30:00",
          "message": "Véhicule entré avec succès"
        }
      }
    },
    "check_out": {
      "request": {
        "method": "POST",
        "url": "http://localhost:8000/api/check-out",
        "body": {
          "ticket_id": "TKT-2024-001"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "success": true,
          "ticket_id": "TKT-2024-001",
          "duration_minutes": 45,
          "amount": 750.0,
          "exit_time": "2024-01-15T11:15:00",
          "message": "Amount à payer: 750 FC"
        }
      }
    },
    "payment": {
      "request": {
        "method": "POST",
        "url": "http://localhost:8000/api/payment",
        "body": {
          "ticket_id": "TKT-2024-001",
          "payment_method": "cash"
        }
      },
      "response": {
        "status": 200,
        "body": {
          "success": true,
          "ticket_id": "TKT-2024-001",
          "amount": 750.0,
          "payment_method": "cash",
          "transaction_id": "TXN-2024-001",
          "message": "Paiement accepté"
        }
      }
    }
  },

