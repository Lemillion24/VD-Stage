{
  "project": {
    "name": "Parking Management System",
    "version": "1.0.0",
    "type": "Backend + Frontend (Architecture séparée)",
    "description": "Système complet de gestion de parking avec API REST (FastAPI) et 3 applications frontend (React + TypeScript)",
    "architecture": "Backend API REST + Frontend Web (séparés)",
    "author": "Harry'son BAGEYA"
  },

  "task": {
    "objective": "Développer un système de gestion de parking avec architecture Backend (API) + Frontend (React)",
    "priority": "HAUTE",
    "complexity": "ÉLEVÉE",
    "deliverables": [
      "Backend API REST complète (FastAPI)",
      "Frontend Agent App (React + TypeScript)",
      "Frontend Client App (React + TypeScript)",
      "Frontend Admin App (React + TypeScript)",
      "Base de données PostgreSQL avec migrations Alembic",
      "Tests unitaires backend + frontend",
      "Configuration Docker + docker-compose",
      "Documentation API complète"
    ]
  },

  "architecture": {
    "pattern": "Backend + Frontend séparés",
    "structure": {
      "backend": {
        "folder": "backend/",
        "tech": "Python + FastAPI",
        "role": "API REST (Backend uniquement)",
        "components": [
          "src/config/ - Pydantic Settings",
          "src/constants/ - Enums (payment_methods, vehicle_types)",
          "src/database/ - SQLAlchemy ORM + Repositories",
          "src/exceptions/ - Custom exceptions métier",
          "src/models/ - ORM SQLAlchemy (Ticket, Place, Parking, Vehicule, Employee)",
          "src/schemas/ - Validation Pydantic (Request/Response)",
          "src/services/ - Business logic (CheckIn, CheckOut, Payment, RateCalculator)",
          "src/utils/ - Helpers (currency, datetime)",
          "src/api/ - FastAPI Routes (check_in.py, check_out.py, payment.py, admin.py)"
        ]
      },
      "frontend": {
        "folder": "frontend/",
        "tech": "TypeScript + React + Vite",
        "role": "Applications Web UX",
        "apps": [
          {
            "name": "agent-app",
            "folder": "frontend/agent-app/",
            "port": 3000,
            "users": "Agents de parking",
            "features": ["Check-In", "Check-Out", "Payment", "Voir tickets", "Voir places"]
          },
          {
            "name": "client-app",
            "folder": "frontend/client-app/",
            "port": 3001,
            "users": "Clients utilisateurs",
            "features": ["Voir ticket", "Payment"]
          },
          {
            "name": "admin-app",
            "folder": "frontend/admin-app/",
            "port": 3002,
            "users": "Administrateurs",
            "features": ["Dashboard", "Parkings", "Tickets", "Employés", "Tarifs", "Reports"]
          }
        ]
      },
      "docker": {
        "folder": "docker/",
        "files": ["docker-compose.yml", "nginx/nginx.conf"],
        "role": "Orchestration des 5 services (backend + agent + client + admin + postgres)"
      }
    }
  },

  "tech_stack": {
    "backend": {
      "language": "Python 3.11+",
      "framework": "FastAPI 0.104.1",
      "orm": "SQLAlchemy 2.0.23",
      "database": "PostgreSQL 14",
      "migrations": "Alembic 1.13.0",
      "validation": "Pydantic 2.5.2",
      "testing": "pytest 7.4.3 + pytest-asyncio",
      "logging": "loguru 0.7.2",
      "auth": "python-jose + passlib"
    },
    "frontend": {
      "language": "TypeScript 5.3.2",
      "framework": "React 18.2.0",
      "build": "Vite 5.0.8",
      "http": "axios 1.6.2",
      "query": "React Query 4.13.0",
      "router": "React Router DOM 6.20.0",
      "testing": "Vitest 0.34.6"
    },
    "deployment": {
      "container": "Docker + Docker-compose",
      "proxy": "Nginx (Reverse Proxy)",
      "ports": {
        "backend": 8000,
        "agent-app": 3000,
        "client-app": 3001,
        "admin-app": 3002,
        "nginx": 80,
        "postgres": 5432
      }
    }
  },

  "backend_endpoints": {
    "base_url": "http://localhost:8000",
    "docs": "http://localhost:8000/docs",
    "routes": [
      {
        "method": "GET",
        "path": "/",
        "description": "Root endpoint - Info API"
      },
      {
        "method": "POST",
        "path": "/api/check-in",
        "description": "Check-in - Faire entrer un véhicule",
        "request": {
          "plate_number": "string",
          "parking_id": "number",
          "vehicle_type": "string (optionnel)",
          "owner_name": "string (optionnel)"
        },
        "response": {
          "success": "boolean",
          "ticket_id": "string",
          "place_number": "string",
          "entry_time": "string (ISO)",
          "message": "string"
        }
      },
      {
        "method": "POST",
        "path": "/api/check-out",
        "description": "Check-out - Calculator amount pour sortie",
        "request": {
          "ticket_id": "string"
        },
        "response": {
          "success": "boolean",
          "ticket_id": "string",
          "duration_minutes": "number",
          "amount": "number",
          "exit_time": "string (ISO)",
          "message": "string"
        }
      },
      {
        "method": "POST",
        "path": "/api/payment",
        "description": "Payment - Traiter paiement",
        "request": {
          "ticket_id": "string",
          "payment_method": "string (cash/card/mobile_money)"
        },
        "response": {
          "success": "boolean",
          "ticket_id": "string",
          "amount": "number",
          "payment_method": "string",
          "transaction_id": "string",
          "message": "string"
        }
      },
      {
        "method": "GET",
        "path": "/api/tarifs",
        "description": "Get info tarifs",
        "response": {
          "tarif_horaire": 500.0,
          "tarif_journalier": 3000.0,
          "delai_grace_minutes": 15,
          "description": "string"
        }
      },
      {
        "method": "GET",
        "path": "/api/parkings",
        "description": "Get tous les parkings avec places disponibles"
      },
      {
        "method": "GET",
        "path": "/api/ticket/{ticket_id}",
        "description": "Get info ticket completo"
      }
    ]
  },

  "business_rules": {
    "tarifs": {
      "TARIF_HORAIRE": 500.0,
      "TARIF_JOURNALIER": 3000.0,
      "DELAI_GRACE": 15,
      "TAXE_PARKING": 0.10
    },
    "formula": "hours * 500 * pricing_factor * 1.10",
    "rules": [
      "15 minutes = gratuit (délai de grâce)",
      "500 FC/heure (tarif horaire)",
      "3000 FC/jour max (tarif journalier)",
      "10% taxe parking incluse",
      "Pricing factor selon type: motorbike=0.5, sedan=1.0, suv=1.2, truck=1.5"
    ],
    "payment_methods": ["cash", "card", "mobile_money", "qr_code"],
    "vehicle_types": ["motorbike", "compact", "sedan", "suv", "truck"],
    "ticket_statuses": ["active", "paid", "expired"],
    "exceptions": {
      "ParkingFullException": "400 - Parking plein",
      "VehicleAlreadyInsideException": "400 - Véhicule déjà inside",
      "TicketNotFoundException": "404 - Ticket non trouvé",
      "TicketAlreadyPaidException": "400 - Ticket déjà payé",
      "PaymentFailedException": "500 - Paiement échoué"
    }
  },

  "database_schema": {
    "tables": [
      {
        "name": "parking",
        "columns": [
          {"name": "id", "type": "Integer", "pk": true},
          {"name": "name", "type": "String(100)", "required": true},
          {"name": "address", "type": "String(200)"},
          {"name": "total_places", "type": "Integer", "required": true},
          {"name": "is_active", "type": "Boolean", "default": true},
          {"name": "created_at", "type": "DateTime"}
        ]
      },
      {
        "name": "places",
        "columns": [
          {"name": "id", "type": "Integer", "pk": true},
          {"name": "place_number", "type": "String(20)", "unique": true},
          {"name": "parking_id", "type": "Integer", "fk": "parking.id"},
          {"name": "place_type", "type": "String(20)", "default": "standard"},
          {"name": "is_occupied", "type": "Boolean", "default": false},
          {"name": "is_available", "type": "Boolean", "default": true}
        ]
      },
      {
        "name": "vehicules",
        "columns": [
          {"name": "id", "type": "Integer", "pk": true},
          {"name": "plate_number", "type": "String(20)", "unique": true, "index": true},
          {"name": "vehicle_type", "type": "String(20)", "required": true},
          {"name": "owner_name", "type": "String(100)"},
          {"name": "is_active", "type": "Boolean", "default": true},
          {"name": "created_at", "type": "DateTime"}
        ]
      },
      {
        "name": "tickets",
        "columns": [
          {"name": "id", "type": "Integer", "pk": true},
          {"name": "ticket_id", "type": "String(50)", "unique": true, "index": true},
          {"name": "vehicule_id", "type": "Integer", "fk": "vehicules.id"},
          {"name": "place_id", "type": "Integer", "fk": "places.id"},
          {"name": "entry_time", "type": "DateTime", "required": true},
          {"name": "exit_time", "type": "DateTime"},
          {"name": "duration_minutes", "type": "Integer", "default": 0},
          {"name": "amount", "type": "Float", "default": 0},
          {"name": "status", "type": "String(20)", "default": "active"},
          {"name": "payment_method", "type": "String(20)"},
          {"name": "is_paid", "type": "Boolean", "default": false}
        ]
      },
      {
        "name": "employees",
        "columns": [
          {"name": "id", "type": "Integer", "pk": true},
          {"name": "employee_id", "type": "String(50)", "unique": true, "index": true},
          {"name": "name", "type": "String(100)", "required": true},
          {"name": "email", "type": "String(100)", "unique": true},
          {"name": "password_hash", "type": "String(255)", "required": true},
          {"name": "role", "type": "String(20)", "default": "agent"},
          {"name": "parking_id", "type": "Integer", "fk": "parking.id"},
          {"name": "is_active", "type": "Boolean", "default": true},
          {"name": "created_at", "type": "DateTime"}
        ]
      }
    ]
  },

  "frontend_components": {
    "agent_app": {
      "pages": [
        "Dashboard.tsx - Dashboard agent (stats, places disponibles)",
        "CheckIn.tsx - Formulaire check-in (plaque, parking, type véhicule)",
        "CheckOut.tsx - Formulaire check-out (ticket ID, voir amount)",
        "Payment.tsx - Formulaire payment (ticket ID, mode paiement)",
        "Tickets.tsx - Liste tickets actifs",
        "Settings.tsx - Configuration (tarifs, parkings)"
      ],
      "components": [
        "CheckInForm.tsx - Formulaire check-in",
        "CheckOutForm.tsx - Formulaire check-out",
        "PaymentForm.tsx - Formulaire payment",
        "TicketList.tsx - Liste tickets",
        "ParkingInfo.tsx - Info parking (places)",
        "Navbar.tsx - Navigation"
      ],
      "services": [
        "api.ts - HTTP client (axios)",
        "checkIn.ts - API check-in",
        "checkOut.ts - API check-out",
        "payment.ts - API payment",
        "admin.ts - API admin"
      ],
      "hooks": [
        "useCheckIn.ts - Hook custom check-in",
        "useCheckOut.ts - Hook custom check-out",
        "usePayment.ts - Hook custom payment"
      ]
    },
    "client_app": {
      "pages": [
        "Home.tsx - Accueil (entres ticket ID)",
        "TicketInfo.tsx - Voir info ticket",
        "Payment.tsx - Payment"
      ],
      "components": [
        "TicketInfo.tsx - Info ticket",
        "PaymentForm.tsx - Formulaire payment",
        "Navbar.tsx - Navigation"
      ]
    },
    "admin_app": {
      "pages": [
        "Dashboard.tsx - Dashboard admin (stats globales)",
        "Parkings.tsx - Gestion parkings (CRUD)",
        "Tickets.tsx - Liste tous tickets",
        "Employees.tsx - Gestion employés (CRUD)",
        "Tarifs.tsx - Configuration tarifs",
        "Reports.tsx - Reports (export CSV, PDF)"
      ]
    }
  },

  "implementation_steps": [
    {
      "step": 1,
      "title": "Créer arborescence Backend",
      "folder": "backend/",
      "actions": [
        "Créer backend/ avec tous les dossiers (src/config, src/constants, src/database, etc.)",
        "Créer backend/src/__init__.py",
        "Créer backend/requirements.txt",
        "Créer backend/alembic.ini",
        "Créer backend/Dockerfile",
        "Créer backend/.env.example"
      ]
    },
    {
      "step": 2,
      "title": "Implémenter Backend - Configuration",
      "folder": "backend/src/config/",
      "files": ["settings.py"],
      "code": "Créer Pydantic Settings avec TARIF_HORAIRE=500, TARIF_JOURNALIER=3000, DELAI_GRACE=15, TAXE=0.10, DATABASE_URL"
    },
    {
      "step": 3,
      "title": "Implémenter Backend - Constants + Exceptions",
      "folder": "backend/src/",
      "files": [
        "constants/payment_methods.py (Enum)",
        "constants/vehicle_types.py (Enum + pricing)",
        "exceptions/parking.py (ParkingFullException, SpotNotFoundException, etc.)",
        "exceptions/payment.py (TicketAlreadyPaidException, PaymentFailedException, etc.)"
      ]
    },
    {
      "step": 4,
      "title": "Implémenter Backend - Database",
      "folder": "backend/src/database/",
      "files": [
        "db_connection.py (engine SQLAlchemy, Session, Base, get_db, init_db)",
        "repositories.py (VehiculeRepository, PlaceRepository, ParkingRepository, TicketRepository, EmployeeRepository avec CRUD)"
      ]
    },
    {
      "step": 5,
      "title": "Implémenter Backend - Models ORM",
      "folder": "backend/src/models/",
      "files": [
