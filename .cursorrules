        "Créer src/App.tsx",
        "Créer src/index.tsx"
      ]
    },
    {
      "step": 17,
      "title": "Implémenter Frontend - Admin App",
      "folder": "frontend/admin-app/",
      "actions": [
        "Créer src/services/api.ts",
        "Créer src/services/admin.ts (getParkings, getTickets, getEmployees, updateTarifs)",
        "Créer src/pages/Dashboard.tsx",
        "Créer src/pages/Parkings.tsx (CRUD parkings)",
        "Créer src/pages/Tickets.tsx (liste tickets)",
        "Créer src/pages/Employees.tsx (CRUD employés)",
        "Créer src/pages/Tarifs.tsx (configuration tarifs)",
        "Créer src/pages/Reports.tsx (export CSV/PDF)",
        "Créer src/App.tsx",
        "Créer src/index.tsx"
      ]
    },
    {
      "step": 18,
      "title": "Implémenter Docker - Orchestration",
      "folder": "docker/",
      "files": [
        "docker-compose.yml (5 services: backend, postgres, agent-app, client-app, admin-app, nginx)",
