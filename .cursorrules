      ]
    },
    {
      "step": 7,
      "title": "Implémenter Backend - Rate Calculator",
      "folder": "backend/src/services/",
      "files": ["rate_calculator.py"],
      "code": "Classe RateCalculator avec calculate(duration_minutes, vehicle_type) selon règles business"
    },
    {
      "step": 8,
      "title": "Implémenter Backend - Services Métier",
      "folder": "backend/src/services/",
      "files": [
        "check_in.py (CheckInService.check_in() - crée ticket, occupe place)",
        "check_out.py (CheckOutService.get_check_out_amount() - calc amount)",
        "payment.py (PaymentService.process_payment() - traite payment, libère place)"
      ]
    },
    {
      "step": 9,
      "title": "Implémenter Backend - Schemas Pydantic",
      "folder": "backend/src/schemas/",
      "files": [
        "check_in.py (CheckInRequest, CheckInResponse)",
        "check_out.py (CheckOutRequest, CheckOutResponse)",
        "payment.py (PaymentRequest, PaymentResponse)"
      ]
    },
    {
      "step": 10,
      "title": "Implémenter Backend - API Routes",
      "folder": "backend/src/api/",
      "files": [
        "router.py (Central APIRouter qui include check_in_router, check_out_router, payment_router, admin_router)",
        "check_in.py (POST /api/check-in endpoint)",
        "check_out.py (POST /api/check-out endpoint)",
        "payment.py (POST /api/payment endpoint)",
        "admin.py (GET /api/admin/tarifs, GET /api/admin/parkings, GET /api/admin/ticket/{id})"
      ]
    },
    {
      "step": 11,
      "title": "Implémenter Backend - Main",
      "folder": "backend/",
      "files": ["main.py"],
      "code": "FastAPI app avec CORS middleware, include api_router, startup/shutdown events, uvicorn.run()"
    },
    {
      "step": 12,
      "title": "Implémenter Backend - Tests",
      "folder": "tests/backend/",
      "files": [
        "test_payment.py (RateCalculator tests: 15min=0, 60min=550, 420min=3000)",
        "test_check_in.py (CheckInService tests)",
        "test_check_out.py (CheckOutService tests)",
        "test_api.py (FastAPI test client)"
      ]
    },
